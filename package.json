{
  "name": "@initx-plugin/manager",
  "type": "module",
  "version": "0.5.0",
  "packageManager": "pnpm@10.33.0",
  "description": "initx plugin manager",
  "author": "imba97",
  "license": "MIT",
  "homepage": "https://github.com/initx-collective/initx-plugin-manager#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:initx-collective/initx-plugin-manager.git"
  },
  "bugs": {
    "url": "https://github.com/initx-collective/initx-plugin-manager/issues"
  },
  "keywords": [
    "initx",
    "initx-plugin"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "stub": "unbuild --stub",
    "build": "unbuild",
    "release": "bumpp",
    "lint": "eslint --cache",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@initx-plugin/core": "*",
    "@initx-plugin/utils": "*"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "columnify": "^1.6.0",
    "fs-extra": "^11.3.4",
    "package-manager-detector": "^1.6.0",
    "pathe": "^2.0.3",
    "stagetty": "^0.1.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@initx-plugin/core": "^0.3.3",
    "@initx-plugin/utils": "^0.3.3",
    "@types/columnify": "^1.5.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "nano-staged": "^0.9.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "unbuild": "^3.6.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
